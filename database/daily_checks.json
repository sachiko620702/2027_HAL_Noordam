    {"id": "shopping_tax_refund", "category": "Shopping", "label": "Department store tax refund rules", "source": "WATCHLIST.md", "note": "Check current Japan tax-free policy."},
    {"id": "shopping_boutique_appointments", "category": "Shopping", "label": "Luxury boutique appointment policy", "source": "WATCHLIST.md", "note": "Check appointment requirements for luxury brands."},
    {"id": "budget_exchange_rate", "category": "Budget", "label": "JPY/TWD exchange rate", "source": "WATCHLIST.md", "note": "Check exchange rate before budgeting."},
    {"id": "budget_credit_card_rewards", "category": "Budget", "label": "Credit card reward rules", "source": "WATCHLIST.md", "note": "Check reward and cashback policy."},
    {"id": "budget_insurance", "category": "Budget", "label": "Travel insurance payment status", "source": "database/budget.yaml", "note": "Confirm whether the TWD 6,900 insurance amount has been paid and by which method."},
    {"id": "budget_phone_roaming", "category": "Budget", "label": "Phone roaming billing", "source": "database/budget.yaml", "note": "Confirm roaming activation, billing method, hotspot rules, and fair-use policy for the TWD 499 two-person plan."},
    {"id": "ticket_platform_policy", "category": "Ticket Platforms", "label": "KKday / Klook cancellation and refund policy", "source": "WATCHLIST.md", "note": "Check platform policy before purchase."},
    {"id": "ticket_platform_kix_transfer", "category": "Ticket Platforms", "label": "KKday KIX airport transfer", "source": "WATCHLIST.md", "note": "Check KKday product, price, vehicle type, luggage rules, waiting time, and delayed-flight handling."}
  ]
